SELECT
  event_date,
  event_name,
  privacy_info.analytics_storage,
  privacy_info.ads_storage,
  privacy_info.uses_transient_token,

  -- 1. Total Volume of Hits
  COUNT(*) AS total_events,
  
  -- 2. Clean User Count (Handles Advanced Cookieless v2 Nulls gracefully)
  COUNT(DISTINCT IFNULL(user_pseudo_id, 'cookieless_ping_user')) AS unique_users,
  
  -- 3. Clean Session Count (Handles Advanced Cookieless v2 Nulls gracefully)
  COUNT(DISTINCT 
    IFNULL(
      CONCAT(user_pseudo_id, CAST((SELECT value.int_value FROM UNNEST(event_params) WHERE key = 'ga_session_id') AS STRING)), 
      'cookieless_ping_session'
    )
  ) AS total_sessions

FROM
  `enter.tablename_123456.events_*`
WHERE
  -- Filters to key milestones to spot tracking anomalies easily
  event_name IN ('session_start', 'purchase')
GROUP BY 
  1, 2, 3, 4, 5
ORDER BY 
  event_date DESC, 
  total_events DESC;
